-                <arg line="-target x64-apple-darwin -arch x86_64" unless:set="build.arch.arm"/>
-                <arg line="-target aarch64-apple-darwin -arch arm64" if:set="build.arch.arm"/>
+                <arg line='-dynamiclib -Wl,-no_compact_unwind -miphoneos-version-min=@{macos} -isysroot ${sdkroot} -o ${lib.arch}/lib${name}.dylib -O3 -flto=auto -fPIC'/>
+                <arg line="-target arm64-apple-ios14.0 -arch arm64"/>
                 <fileset dir="${dest}" includes="*.o"/>
                 <link/>
             </apply>
@@ -141,7 +135,7 @@
         <parallel threadsPerProcessor="2">
 
         <!-- CORE -->
-        <build module="core" flags="-Werror -Wfatal-errors -Wall -Wextra -pedantic">
+        <build module="core" flags="-Wall -Wextra -pedantic">
             <source>
                 <arg value="-I${src.main.rel}/libffi"/>
                 <arg value="-I${src.main.rel}/libffi/aarch64" if:set="build.arch.arm64"/>
