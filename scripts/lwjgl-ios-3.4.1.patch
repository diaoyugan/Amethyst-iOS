diff --git a/config/macos/build.xml b/config/macos/build.xml
index 98204971..10000000 100644
--- a/config/macos/build.xml
+++ b/config/macos/build.xml
@@ -5,17 +5,13 @@
 <project name="native-macos" basedir="../.." xmlns:if="ant:if" xmlns:unless="ant:unless">
     <import file="../build-definitions.xml"/>
 
-    <!-- Find the macOS SDK root. -->
+    <!-- LWJGL has no iOS platform target. Reuse the Darwin sources with the iPhoneOS SDK. -->
     <exec executable="xcrun" outputproperty="sdkroot" failonerror="true">
-        <arg line="--show-sdk-path --sdk macosx"/>
+        <arg line="--show-sdk-path --sdk iphoneos"/>
     </exec>
 
-    <condition property="macosx-version-min" value="11.0" else="10.11">
